// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/javascript-node
{
  "name": "Node.js",
  // Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
  "image": "mcr.microsoft.com/devcontainers/typescript-node:1-22-bullseye",
  "runArgs": [
    "--name",
    "neko-games",
    "--add-host=host.docker.internal:host-gateway",
    "-p",
    "5173:5173"
  ],

  // AI エージェント永続化
  "mounts": [
    "source=${localEnv:HOME}/.agent/codex/test-games/.codex,target=/home/node/.codex,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.claude,target=/home/node/.claude,type=bind,consistency=cached"
  ],

  // Features to add to the dev container. More info: https://containers.dev/features.
  // "features": {},

  // Use 'forwardPorts' to make a list of ports inside the container available locally.
  "forwardPorts": [5173],

  // Use 'postCreateCommand' to run commands after the container is created.
  "postCreateCommand": "npm install && npm install -g @anthropic-ai/claude-code",

  // Configure tool-specific properties.
  "customizations": {
    "vscode": {
      "extensions": ["openai.chatgpt", "biomejs.biome"],
      "settings": {
        "editor.codeActionsOnSave": {
          "source.fixAll": "never",
          "source.fixAll.eslint": "explicit"
        },
        "editor.tabSize": 2
      }
    }
  }

  // Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
  // "remoteUser": "root"
}
